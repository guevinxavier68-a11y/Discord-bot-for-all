# Copy this file to .env and fill in your values

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your bot's application/client ID
CLIENT_ID=your_client_id_here

# Your Discord user ID (for owner-only commands like /create-key and /delete-key)
OWNER_ID=your_discord_user_id_here

# Guild ID for testing (optional — if set, commands register to this guild instantly)
# Leave empty to register commands globally (takes up to 1 hour)
GUILD_ID=
